      "package": "com.stockroom.inventory",
      "backgroundColor": "#12151A",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Stockroom to use your camera to scan barcodes."
        }
      ]
    ]
  }
}
